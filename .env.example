# [Production = prod, Development = dev]
ENV=prod

# [LevelDebug = -4, LevelInfo = 0, LevelWarn = 4, LevelError = 8]
LOGGER_LEVEL=0


HTTP_SERVER_PORT=8080
HTTP_SERVER_READ_TIMEOUT=10s
HTTP_SERVER_READ_HEADER_TIMEOUT=2s
HTTP_SERVER_WRITE_TIMEOUT=10s
HTTP_SERVER_IDLE_TIMEOUT=60s
HTTP_SERVER_MAX_HEADER_BYTES=500
HTTP_SERVER_SHUTDOWN_TIMEOUT=10s

HTTP_SERVER_READINESS_TIMEOUT=5s